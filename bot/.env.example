# Telegram bot token — create one via @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# football-data.org free-tier API key. Without this the bot still works,
# but live data falls back to the static schedule.
FOOTBALL_DATA_API_KEY=

# IANA timezone used for the daily 9am digest cron. Defaults to UTC.
DIGEST_TIMEZONE=UTC

# Where to persist user prefs (favorite team, language). Defaults to ./data/users.json.
# On Railway, mount a volume here for cross-restart persistence.
USERS_FILE=./data/users.json

# Goal-alert poll interval in seconds (default 60).
POLL_INTERVAL_SEC=60
