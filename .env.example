# football-data.org free-tier API key — sign up at https://www.football-data.org/client/register
# Without this, live scores fall back to placeholder data and the UI still renders.
FOOTBALL_DATA_API_KEY=

# Optional: Upstash Redis (used to persist cache across serverless invocations on Vercel).
# When unset, lib/cache.ts uses an in-memory store that's per-process only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: public link to the Telegram bot (rendered in the Footer CTA).
# Replace with your @BotFather handle once the bot is live.
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/footballclean_bot

# Canonical site URL — used by metadata, sitemap, robots, and OG tags.
NEXT_PUBLIC_SITE_URL=https://footballclean.app

# Plausible Analytics — privacy-friendly, no cookies. Leave blank to disable.
# (Free tier is fine for our launch scale; self-hosting works the same way.)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional: Sentry DSN for client-side error reporting (we use the envelope
# endpoint directly so no SDK is shipped to the browser). Free tier is enough.
NEXT_PUBLIC_SENTRY_DSN=

# Web Push (VAPID) keys for browser notifications.
# Generate with: npx web-push generate-vapid-keys
# The public key is exposed to the client (NEXT_PUBLIC_ prefix) so the browser
# can subscribe; the private key stays server-side and signs outgoing pushes.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@footballclean.app
