{
  "manifest_version": 3,
  "name": "Clean Stream by FootballClean",
  "short_name": "Clean Stream",
  "version": "0.1.0",
  "description": "Block popup ads, fake play buttons, malware overlays, and adult/gambling ads on football streaming sites. Halal-friendly.",
  "author": "FootballClean",
  "homepage_url": "https://footballclean.com",
  "minimum_chrome_version": "108",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Clean Stream",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://*.google.com/*",
        "https://*.gmail.com/*",
        "https://*.youtube.com/*",
        "https://*.github.com/*",
        "https://*.bankid.com/*",
        "https://*.paypal.com/*",
        "https://*.stripe.com/*"
      ],
      "js": ["content/detector.js", "content/blocker.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adult_gambling_block",
        "enabled": true,
        "path": "rules/adult_gambling.json"
      },
      {
        "id": "malware_block",
        "enabled": true,
        "path": "rules/malware.json"
      },
      {
        "id": "popup_trackers",
        "enabled": true,
        "path": "rules/popup_trackers.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["content/injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
